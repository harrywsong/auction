{
  "name": "auction-server",
  "version": "1.0.0",
  "description": "Express server for 뽀낳대 auction platform",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --loader ts-node/esm src/main.ts",
